// Maestro Platform — foundational data model
// Universal learning core (direction-agnostic). No domain-specific tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MaterialType {
  pdf
  image
  file
  link
}

enum DifficultyLevel {
  beginner
  intermediate
  advanced
  all_levels
}

enum StudentCourseStatus {
  enrolled
  active
  completed
  paused
  cancelled
}

enum LessonProgressStatus {
  locked
  available
  in_progress
  submitted
  reviewed
  completed
}

enum LessonQuestionStatus {
  pending
  answered
}

enum HomeworkSubmissionStatus {
  pending
  submitted
  under_review
  approved
  rejected
}

enum HomeworkAttachmentType {
  text
  video
  audio
  file
}

enum HomeworkType {
  assignment
  test
}

enum OnlineLessonRequestStatus {
  new
  assigned
  scheduled
  completed
  cancelled
  no_show
}

enum OnlineLessonMaterialType {
  youtube
  link
  text
  pdf
  image
  file
}

enum OnlineLessonAssignmentSubmissionStatus {
  submitted
  approved
  approved_with_remarks
  returned
}

enum MaestroCoinTransactionType {
  earn
  adjustment
  correction
}

enum MaestroCoinSourceType {
  online_lesson
  assignment
  course
  manual
}

enum AuditAction {
  create
  update
  delete
  restore
  publish
  unpublish
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(64)
  slug        String   @unique @db.VarChar(64)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users           User[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(128)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([code])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─── Multi-tenancy (future — schema only) ───────────────────────────────────

model School {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(128)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  branches   Branch[]
  directions Direction[]

  @@index([slug])
  @@index([deletedAt])
  @@map("schools")
}

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  title     String    @db.VarChar(255)
  slug      String    @db.VarChar(128)
  address   String?   @db.VarChar(512)
  phone     String?   @db.VarChar(32)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachers Teacher[]
  courses  Course[]

  @@unique([schoolId, slug])
  @@index([schoolId])
  @@index([deletedAt])
  @@map("branches")
}

model Teacher {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  title     String?   @db.VarChar(255)
  bio       String?   @db.Text
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([deletedAt])
  @@map("teachers")
}

// ─── Users ───────────────────────────────────────────────────────────────────

enum UserNotificationType {
  online_lesson_assigned
  online_lesson_scheduled
  online_lesson_rescheduled
  online_lesson_cancelled
  online_lesson_no_show
  online_lesson_completed
  online_assignment_submitted
  online_assignment_reviewed
  offline_lesson_approved
  offline_lesson_report_ready
  offline_lesson_returned
  offline_lesson_cancelled
  offline_lesson_rescheduled
  direct_message_received
  homework_submitted
  homework_reviewed
  lesson_question_received
  lesson_question_answered
  achievement_earned
  points_awarded
  coins_awarded
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  login        String?   @unique @db.VarChar(64)
  email        String?   @unique @db.VarChar(255)
  phone        String    @db.VarChar(32)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(128)
  lastName     String    @map("last_name") @db.VarChar(128)
  middleName   String?   @map("middle_name") @db.VarChar(128)
  avatar       String?   @db.VarChar(512)
  profileBio   String?   @map("profile_bio") @db.Text
  profileInstrument String? @map("profile_instrument") @db.VarChar(128)
  profileInterests String[] @default([]) @map("profile_interests")
  profilePublic Boolean @default(false) @map("profile_public")
  roleId       String    @map("role_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")

  // Integration: CRM user link
  crmStudentId         String?   @unique @map("crm_student_id") @db.VarChar(64)
  crmTeacherId         String?   @unique @map("crm_teacher_id") @db.VarChar(64)
  phoneNormalized      String?   @unique @map("phone_normalized") @db.VarChar(32)
  externalLinkStatus   String?   @map("external_link_status") @db.VarChar(32)
  linkedAt             DateTime? @map("linked_at") @db.Timestamptz(6)

  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  role Role @relation(fields: [roleId], references: [id])

  teacherProfile       Teacher?
  studentCourses       StudentCourse[]
  lessonProgress       LessonProgress[]
  homeworkSubmissions  HomeworkSubmission[] @relation("HomeworkStudent")
  reviewedSubmissions  HomeworkSubmission[] @relation("HomeworkReviewer")
  pointsReceived       PointsTransaction[]  @relation("PointsStudent")
  pointsAwarded        PointsTransaction[]  @relation("PointsAwarder")
  achievements         StudentAchievement[]
  newsPosts            NewsPost[]
  auditLogs            AuditLog[]
  pushSubscriptions    PushSubscription[]
  lessonQuestions      LessonQuestion[]
  onlineLessonRequestsAsStudent OnlineLessonRequest[] @relation("OnlineLessonStudent")
  onlineLessonRequestsAsTeacher OnlineLessonRequest[] @relation("OnlineLessonTeacher")
  onlineLessonRequestsCompleted OnlineLessonRequest[] @relation("OnlineLessonCompleter")
  onlineLessonAssignmentSubmissions OnlineLessonAssignmentSubmission[] @relation("OnlineAssignmentStudent")
  onlineLessonAssignmentReviews OnlineLessonAssignmentSubmission[] @relation("OnlineAssignmentReviewer")
  coinBalance              StudentCoinBalance?
  maestroCoinTransactions  MaestroCoinTransaction[] @relation("CoinStudent")
  maestroCoinsAwarded      MaestroCoinTransaction[] @relation("CoinAwarder")
  notifications            UserNotification[]
  offlineLessonStudentChecks OfflineLessonStudentCheck[]
  messageConversationsAsStudent TeacherConversation[] @relation("TeacherConversationStudent")
  messageConversationsAsTeacher TeacherConversation[] @relation("TeacherConversationTeacher")
  directMessages              TeacherMessage[] @relation("TeacherMessageSender")

  @@index([roleId])
  @@index([email])
  @@index([login])
  @@index([isActive])
  @@index([deletedAt])

  @@index([crmStudentId])
  @@index([crmTeacherId])
  @@map("users")
}

model OfflineLessonStudentCheck {
  id                         String   @id @default(uuid()) @db.Uuid
  crmClassId                 String   @map("crm_class_id") @db.VarChar(128)
  crmStudentId               String   @map("crm_student_id") @db.VarChar(128)
  teacherUserId              String?  @map("teacher_user_id") @db.Uuid
  attendanceStatus           String   @default("unmarked") @map("attendance_status") @db.VarChar(32)
  homeworkStatus             String   @default("not_checked") @map("homework_status") @db.VarChar(32)
  homeworkCompletionPercent  Int?     @map("homework_completion_percent")
  homeworkDifficulties       String?  @map("homework_difficulties") @db.Text
  homeworkNotCompletedReason String?  @map("homework_not_completed_reason") @db.Text
  teacherNote                String?  @map("teacher_note") @db.Text
  markedAt                   DateTime @default(now()) @map("marked_at") @db.Timestamptz(6)
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacherUser User? @relation(fields: [teacherUserId], references: [id], onDelete: SetNull)

  @@unique([crmClassId, crmStudentId])
  @@index([teacherUserId])
  @@index([crmClassId])
  @@map("offline_lesson_student_checks")
}

// ─── Learning catalog ────────────────────────────────────────────────────────

model Direction {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String?   @map("school_id") @db.Uuid
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(128)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.VarChar(1024)
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  courses              Course[]
  onlineLessonRequests OnlineLessonRequest[]

  @@index([slug])
  @@index([isPublished])
  @@index([schoolId])
  @@index([deletedAt])
  @@map("directions")
}

model Course {
  id              String          @id @default(uuid()) @db.Uuid
  directionId     String          @map("direction_id") @db.Uuid
  branchId        String?         @map("branch_id") @db.Uuid
  title           String          @db.VarChar(255)
  description     String?         @db.Text
  thumbnail       String?         @db.VarChar(512)
  difficultyLevel DifficultyLevel @default(beginner) @map("difficulty_level")
  completionCoinsReward Int       @default(0) @map("completion_coins_reward")
  isPublished     Boolean         @default(false) @map("is_published")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(6)

  direction      Direction       @relation(fields: [directionId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  modules        CourseModule[]
  studentCourses StudentCourse[]
  signupLessons  Lesson[] @relation("LessonSignupCourse")

  @@index([directionId])
  @@index([branchId])
  @@index([isPublished])
  @@index([deletedAt])
  @@map("courses")
}

model CourseModule {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, sortOrder])
  @@index([deletedAt])
  @@map("course_modules")
}

model Lesson {
  id           String    @id @default(uuid()) @db.Uuid
  moduleId     String    @map("module_id") @db.Uuid
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  videoUrl     String?   @map("video_url") @db.VarChar(512)
  sortOrder    Int       @default(0) @map("sort_order")
  pointsReward Int       @default(0) @map("points_reward")
  isPublished  Boolean   @default(false) @map("is_published")
  enableAskTeacher   Boolean @default(false) @map("enable_ask_teacher")
  enableLessonSignup Boolean @default(false) @map("enable_lesson_signup")
  signupCourseId     String? @map("signup_course_id") @db.Uuid
  signupExternalUrl  String? @map("signup_external_url") @db.VarChar(1024)
  signupLabel        String? @map("signup_label") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  module          CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  signupCourse    Course?          @relation("LessonSignupCourse", fields: [signupCourseId], references: [id], onDelete: SetNull)
  materials       LessonMaterial[]
  homeworks       Homework[]
  lessonProgress      LessonProgress[]
  pointsTransactions PointsTransaction[]
  questions       LessonQuestion[]

  @@index([moduleId, sortOrder])
  @@index([isPublished])
  @@index([deletedAt])
  @@index([signupCourseId])
  @@map("lessons")
}

model LessonQuestion {
  id        String               @id @default(uuid()) @db.Uuid
  lessonId  String               @map("lesson_id") @db.Uuid
  studentId String               @map("student_id") @db.Uuid
  message   String               @db.Text
  status    LessonQuestionStatus @default(pending)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([lessonId, status, createdAt])
  @@index([studentId])
  @@map("lesson_questions")
}

model LessonMaterial {
  id        String       @id @default(uuid()) @db.Uuid
  lessonId  String       @map("lesson_id") @db.Uuid
  type      MaterialType
  title     String       @db.VarChar(255)
  url       String       @db.VarChar(1024)
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, sortOrder])
  @@map("lesson_materials")
}

// ─── Enrollment & progress ─────────────────────────────────────────────────

model StudentCourse {
  id         String              @id @default(uuid()) @db.Uuid
  studentId  String              @map("student_id") @db.Uuid
  courseId   String              @map("course_id") @db.Uuid
  status     StudentCourseStatus @default(enrolled)
  enrolledAt DateTime            @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId, status])
  @@index([courseId])
  @@map("student_courses")
}

model LessonProgress {
  id          String               @id @default(uuid()) @db.Uuid
  studentId   String               @map("student_id") @db.Uuid
  lessonId    String               @map("lesson_id") @db.Uuid
  status      LessonProgressStatus @default(locked)
  completedAt DateTime?            @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId, status])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ─── Homework ────────────────────────────────────────────────────────────────

model Homework {
  id            String       @id @default(uuid()) @db.Uuid
  lessonId      String       @map("lesson_id") @db.Uuid
  description   String       @db.Text
  type          HomeworkType @default(assignment)
  testQuestions Json?        @map("test_questions") @db.JsonB
  passingScore  Int          @default(70) @map("passing_score")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([lessonId])
  @@index([deletedAt])
  @@map("homeworks")
}

model HomeworkSubmission {
  id            String                   @id @default(uuid()) @db.Uuid
  homeworkId    String                   @map("homework_id") @db.Uuid
  studentId     String                   @map("student_id") @db.Uuid
  comment        String?                   @db.Text
  reviewComment  String?                   @map("review_comment") @db.Text
  attachmentUrl  String?                   @map("attachment_url") @db.VarChar(1024)
  attachmentType HomeworkAttachmentType?   @map("attachment_type")
  testAnswers    Json?                     @map("test_answers") @db.JsonB
  testScore      Int?                      @map("test_score")
  testPassed     Boolean?                  @map("test_passed")
  status         HomeworkSubmissionStatus  @default(submitted)
  reviewedById  String?                  @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    User     @relation("HomeworkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("HomeworkReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([homeworkId])
  @@index([studentId, status])
  @@index([reviewedById])
  @@map("homework_submissions")
}

// ─── Gamification (ledger-only balance) ────────────────────────────────────

model PointsTransaction {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  amount     Int
  reason     String   @db.VarChar(512)
  lessonId   String?  @map("lesson_id") @db.Uuid
  awardedBy  String?  @map("awarded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  student User    @relation("PointsStudent", fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  awarder User?   @relation("PointsAwarder", fields: [awardedBy], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([studentId, lessonId])
  @@index([awardedBy])
  @@map("points_transactions")
}

// ─── Achievements (learning engine — schema only in UI) ─────────────────────

enum AchievementCriteriaType {
  first_lesson_completed
  points_threshold
  first_module_completed
  lessons_completed_count
}

model Achievement {
  id           String                  @id @default(uuid()) @db.Uuid
  code         String                  @unique @db.VarChar(64)
  title        String                  @db.VarChar(255)
  description  String?                 @db.Text
  criteriaType AchievementCriteriaType @map("criteria_type")
  threshold    Int                     @default(0)
  isActive     Boolean                 @default(true) @map("is_active")
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentAchievements StudentAchievement[]

  @@index([code])
  @@index([criteriaType])
  @@map("achievements")
}

model StudentAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at") @db.Timestamptz(6)

  student     User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementId])
  @@index([studentId])
  @@index([achievementId])
  @@map("student_achievements")
}

// ─── Maestro Board ───────────────────────────────────────────────────────────

model NewsPost {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  content     String    @db.Text
  authorId    String    @map("author_id") @db.Uuid
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([isPublished, publishedAt])
  @@index([authorId])
  @@index([deletedAt])
  @@map("news_posts")
}

// ─── Online lessons (Zoom, separate from course lessons) ─────────────────────

model OnlineLessonRequest {
  id              String                    @id @default(uuid()) @db.Uuid
  studentId       String                    @map("student_id") @db.Uuid
  directionId     String?                   @map("direction_id") @db.Uuid
  directionTitle  String                    @map("direction_title") @db.VarChar(255)
  level           String                    @db.VarChar(128)
  preferredTime   String                    @map("preferred_time") @db.VarChar(512)
  comment         String?                   @db.Text
  status          OnlineLessonRequestStatus @default(new)
  teacherId       String?                   @map("teacher_id") @db.Uuid
  scheduledAt     DateTime?                 @map("scheduled_at") @db.Timestamptz(6)
  zoomUrl         String?                   @map("zoom_url") @db.VarChar(1024)
  coveredTopics   String?                   @map("covered_topics") @db.Text
  whatWorked      String?                   @map("what_worked") @db.Text
  whatToImprove   String?                   @map("what_to_improve") @db.Text
  completionComment String?                 @map("completion_comment") @db.Text
  lessonPoints    Int                       @default(0) @map("lesson_points")
  lessonCoins     Int                       @default(0) @map("lesson_coins")
  lessonCoinsReason String?                 @map("lesson_coins_reason") @db.VarChar(512)
  completedAt     DateTime?                 @map("completed_at") @db.Timestamptz(6)
  completedById   String?                   @map("completed_by") @db.Uuid
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)

  student     User       @relation("OnlineLessonStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User?      @relation("OnlineLessonTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  completedBy User?      @relation("OnlineLessonCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  direction   Direction? @relation(fields: [directionId], references: [id], onDelete: SetNull)
  assignment  OnlineLessonAssignment?

  @@index([studentId, status, createdAt])
  @@index([teacherId, status])
  @@index([status, createdAt])
  @@map("online_lesson_requests")
}

model OnlineLessonAssignment {
  id               String                 @id @default(uuid()) @db.Uuid
  requestId        String                 @unique @map("request_id") @db.Uuid
  title            String                 @db.VarChar(255)
  description      String                 @db.Text
  dueAt            DateTime?              @map("due_at") @db.Timestamptz(6)
  submissionFormat HomeworkAttachmentType @map("submission_format")
  pointsReward     Int                    @default(0) @map("points_reward")
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  request     OnlineLessonRequest              @relation(fields: [requestId], references: [id], onDelete: Cascade)
  materials   OnlineLessonAssignmentMaterial[]
  submissions OnlineLessonAssignmentSubmission[]

  @@map("online_lesson_assignments")
}

model OnlineLessonAssignmentMaterial {
  id           String                   @id @default(uuid()) @db.Uuid
  assignmentId String                   @map("assignment_id") @db.Uuid
  type         OnlineLessonMaterialType
  title        String                   @db.VarChar(255)
  url          String?                  @db.VarChar(1024)
  content      String?                  @db.Text
  sortOrder    Int                      @default(0) @map("sort_order")
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  assignment OnlineLessonAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, sortOrder])
  @@map("online_lesson_assignment_materials")
}

model OnlineLessonAssignmentSubmission {
  id               String                               @id @default(uuid()) @db.Uuid
  assignmentId     String                               @map("assignment_id") @db.Uuid
  studentId        String                               @map("student_id") @db.Uuid
  comment          String?                              @db.Text
  attachmentUrl    String?                              @map("attachment_url") @db.VarChar(1024)
  attachmentType   HomeworkAttachmentType?            @map("attachment_type")
  status           OnlineLessonAssignmentSubmissionStatus @default(submitted)
  reviewComment    String?                              @map("review_comment") @db.Text
  reviewPoints     Int?                                 @map("review_points")
  reviewCoins      Int                                  @default(0) @map("review_coins")
  reviewCoinsReason String?                             @map("review_coins_reason") @db.VarChar(512)
  reviewedById     String?                              @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime?                            @map("reviewed_at") @db.Timestamptz(6)
  createdAt        DateTime                             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                             @updatedAt @map("updated_at") @db.Timestamptz(6)

  assignment OnlineLessonAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User                   @relation("OnlineAssignmentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy User?                  @relation("OnlineAssignmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([assignmentId, studentId, createdAt])
  @@index([studentId, status])
  @@map("online_lesson_assignment_submissions")
}

// ─── Maestro Coins (manual awards only — no shop yet) ────────────────────────

model StudentCoinBalance {
  id        String   @id @default(uuid()) @db.Uuid
  studentId String   @unique @map("student_id") @db.Uuid
  balance   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_coin_balances")
}

model MaestroCoinTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  studentId       String                   @map("student_id") @db.Uuid
  amount          Int
  transactionType MaestroCoinTransactionType @map("transaction_type")
  reason          String                   @db.VarChar(512)
  sourceType      MaestroCoinSourceType    @map("source_type")
  sourceId        String?                  @map("source_id") @db.Uuid
  createdById     String                   @map("created_by") @db.Uuid
  balanceBefore   Int                      @map("balance_before")
  balanceAfter    Int                      @map("balance_after")
  createdAt       DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  student   User @relation("CoinStudent", fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User @relation("CoinAwarder", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([studentId, createdAt])
  @@index([sourceType, sourceId])
  @@map("maestro_coin_transactions")
}

// ─── In-app notifications ────────────────────────────────────────────────────

model UserNotification {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @map("user_id") @db.Uuid
  type      UserNotificationType
  title     String               @db.VarChar(255)
  body      String               @db.Text
  url       String?              @db.VarChar(512)
  readAt    DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("user_notifications")
}

// ─── Student and teacher mailbox ────────────────────────────────────────────

model TeacherConversation {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  teacherId     String   @map("teacher_id") @db.Uuid
  lastMessageAt DateTime @default(now()) @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  student  User             @relation("TeacherConversationStudent", fields: [studentId], references: [id], onDelete: Cascade)
  teacher  User             @relation("TeacherConversationTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  messages TeacherMessage[]

  @@unique([studentId, teacherId])
  @@index([studentId, lastMessageAt(sort: Desc)])
  @@index([teacherId, lastMessageAt(sort: Desc)])
  @@map("teacher_conversations")
}

model TeacherMessage {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  body           String    @db.Text
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation TeacherConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation("TeacherMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
  @@index([senderId])
  @@map("teacher_messages")
}

// ─── Push notifications ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.VarChar(2048)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  entityType String      @map("entity_type") @db.VarChar(64)
  entityId   String      @map("entity_id") @db.Uuid
  action     AuditAction
  actorId    String?     @map("actor_id") @db.Uuid
  payload    Json?       @db.JsonB
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
