// Maestro Platform — foundational data model
// Universal learning core (direction-agnostic). No domain-specific tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MaterialType {
  pdf
  image
  file
  link
}

enum DifficultyLevel {
  beginner
  intermediate
  advanced
  all_levels
}

enum StudentCourseStatus {
  enrolled
  active
  completed
  paused
  cancelled
}

enum LessonProgressStatus {
  locked
  available
  in_progress
  submitted
  reviewed
  completed
}

enum LessonQuestionStatus {
  pending
  answered
}

enum HomeworkSubmissionStatus {
  pending
  submitted
  under_review
  approved
  rejected
}

enum HomeworkAttachmentType {
  text
  video
  audio
  file
}

enum HomeworkType {
  assignment
  test
}

enum AuditAction {
  create
  update
  delete
  restore
  publish
  unpublish
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(64)
  slug        String   @unique @db.VarChar(64)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users           User[]
  rolePermissions RolePermission[]

  @@index([slug])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(128)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]

  @@index([code])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ─── Multi-tenancy (future — schema only) ───────────────────────────────────

model School {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(128)
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  branches   Branch[]
  directions Direction[]

  @@index([slug])
  @@index([deletedAt])
  @@map("schools")
}

model Branch {
  id        String    @id @default(uuid()) @db.Uuid
  schoolId  String    @map("school_id") @db.Uuid
  title     String    @db.VarChar(255)
  slug      String    @db.VarChar(128)
  address   String?   @db.VarChar(512)
  phone     String?   @db.VarChar(32)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachers Teacher[]
  courses  Course[]

  @@unique([schoolId, slug])
  @@index([schoolId])
  @@index([deletedAt])
  @@map("branches")
}

model Teacher {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @unique @map("user_id") @db.Uuid
  branchId  String?   @map("branch_id") @db.Uuid
  title     String?   @db.VarChar(255)
  bio       String?   @db.Text
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([deletedAt])
  @@map("teachers")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  phone        String?   @db.VarChar(32)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String    @map("first_name") @db.VarChar(128)
  lastName     String    @map("last_name") @db.VarChar(128)
  avatar       String?   @db.VarChar(512)
  roleId       String    @map("role_id") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  role Role @relation(fields: [roleId], references: [id])

  teacherProfile       Teacher?
  studentCourses       StudentCourse[]
  lessonProgress       LessonProgress[]
  homeworkSubmissions  HomeworkSubmission[] @relation("HomeworkStudent")
  reviewedSubmissions  HomeworkSubmission[] @relation("HomeworkReviewer")
  pointsReceived       PointsTransaction[]  @relation("PointsStudent")
  pointsAwarded        PointsTransaction[]  @relation("PointsAwarder")
  achievements         StudentAchievement[]
  newsPosts            NewsPost[]
  auditLogs            AuditLog[]
  pushSubscriptions    PushSubscription[]
  lessonQuestions      LessonQuestion[]

  @@index([roleId])
  @@index([email])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

// ─── Learning catalog ────────────────────────────────────────────────────────

model Direction {
  id          String    @id @default(uuid()) @db.Uuid
  schoolId    String?   @map("school_id") @db.Uuid
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(128)
  description String?   @db.Text
  imageUrl    String?   @map("image_url") @db.VarChar(1024)
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  school  School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  courses Course[]

  @@index([slug])
  @@index([isPublished])
  @@index([schoolId])
  @@index([deletedAt])
  @@map("directions")
}

model Course {
  id              String          @id @default(uuid()) @db.Uuid
  directionId     String          @map("direction_id") @db.Uuid
  branchId        String?         @map("branch_id") @db.Uuid
  title           String          @db.VarChar(255)
  description     String?         @db.Text
  thumbnail       String?         @db.VarChar(512)
  difficultyLevel DifficultyLevel @default(beginner) @map("difficulty_level")
  isPublished     Boolean         @default(false) @map("is_published")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(6)

  direction      Direction       @relation(fields: [directionId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  modules        CourseModule[]
  studentCourses StudentCourse[]
  signupLessons  Lesson[] @relation("LessonSignupCourse")

  @@index([directionId])
  @@index([branchId])
  @@index([isPublished])
  @@index([deletedAt])
  @@map("courses")
}

model CourseModule {
  id          String    @id @default(uuid()) @db.Uuid
  courseId    String    @map("course_id") @db.Uuid
  title       String    @db.VarChar(255)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, sortOrder])
  @@index([deletedAt])
  @@map("course_modules")
}

model Lesson {
  id           String    @id @default(uuid()) @db.Uuid
  moduleId     String    @map("module_id") @db.Uuid
  title        String    @db.VarChar(255)
  description  String?   @db.Text
  videoUrl     String?   @map("video_url") @db.VarChar(512)
  sortOrder    Int       @default(0) @map("sort_order")
  pointsReward Int       @default(0) @map("points_reward")
  isPublished  Boolean   @default(false) @map("is_published")
  enableAskTeacher   Boolean @default(false) @map("enable_ask_teacher")
  enableLessonSignup Boolean @default(false) @map("enable_lesson_signup")
  signupCourseId     String? @map("signup_course_id") @db.Uuid
  signupExternalUrl  String? @map("signup_external_url") @db.VarChar(1024)
  signupLabel        String? @map("signup_label") @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  module          CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  signupCourse    Course?          @relation("LessonSignupCourse", fields: [signupCourseId], references: [id], onDelete: SetNull)
  materials       LessonMaterial[]
  homeworks       Homework[]
  lessonProgress      LessonProgress[]
  pointsTransactions PointsTransaction[]
  questions       LessonQuestion[]

  @@index([moduleId, sortOrder])
  @@index([isPublished])
  @@index([deletedAt])
  @@index([signupCourseId])
  @@map("lessons")
}

model LessonQuestion {
  id        String               @id @default(uuid()) @db.Uuid
  lessonId  String               @map("lesson_id") @db.Uuid
  studentId String               @map("student_id") @db.Uuid
  message   String               @db.Text
  status    LessonQuestionStatus @default(pending)
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([lessonId, status, createdAt])
  @@index([studentId])
  @@map("lesson_questions")
}

model LessonMaterial {
  id        String       @id @default(uuid()) @db.Uuid
  lessonId  String       @map("lesson_id") @db.Uuid
  type      MaterialType
  title     String       @db.VarChar(255)
  url       String       @db.VarChar(1024)
  sortOrder Int          @default(0) @map("sort_order")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, sortOrder])
  @@map("lesson_materials")
}

// ─── Enrollment & progress ─────────────────────────────────────────────────

model StudentCourse {
  id         String              @id @default(uuid()) @db.Uuid
  studentId  String              @map("student_id") @db.Uuid
  courseId   String              @map("course_id") @db.Uuid
  status     StudentCourseStatus @default(enrolled)
  enrolledAt DateTime            @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId, status])
  @@index([courseId])
  @@map("student_courses")
}

model LessonProgress {
  id          String               @id @default(uuid()) @db.Uuid
  studentId   String               @map("student_id") @db.Uuid
  lessonId    String               @map("lesson_id") @db.Uuid
  status      LessonProgressStatus @default(locked)
  completedAt DateTime?            @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId, status])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ─── Homework ────────────────────────────────────────────────────────────────

model Homework {
  id            String       @id @default(uuid()) @db.Uuid
  lessonId      String       @map("lesson_id") @db.Uuid
  description   String       @db.Text
  type          HomeworkType @default(assignment)
  testQuestions Json?        @map("test_questions") @db.JsonB
  passingScore  Int          @default(70) @map("passing_score")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([lessonId])
  @@index([deletedAt])
  @@map("homeworks")
}

model HomeworkSubmission {
  id            String                   @id @default(uuid()) @db.Uuid
  homeworkId    String                   @map("homework_id") @db.Uuid
  studentId     String                   @map("student_id") @db.Uuid
  comment        String?                   @db.Text
  reviewComment  String?                   @map("review_comment") @db.Text
  attachmentUrl  String?                   @map("attachment_url") @db.VarChar(1024)
  attachmentType HomeworkAttachmentType?   @map("attachment_type")
  testAnswers    Json?                     @map("test_answers") @db.JsonB
  testScore      Int?                      @map("test_score")
  testPassed     Boolean?                  @map("test_passed")
  status         HomeworkSubmissionStatus  @default(submitted)
  reviewedById  String?                  @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    User     @relation("HomeworkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("HomeworkReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([homeworkId])
  @@index([studentId, status])
  @@index([reviewedById])
  @@map("homework_submissions")
}

// ─── Gamification (ledger-only balance) ────────────────────────────────────

model PointsTransaction {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  amount     Int
  reason     String   @db.VarChar(512)
  lessonId   String?  @map("lesson_id") @db.Uuid
  awardedBy  String?  @map("awarded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  student User    @relation("PointsStudent", fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  awarder User?   @relation("PointsAwarder", fields: [awardedBy], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@index([studentId, lessonId])
  @@index([awardedBy])
  @@map("points_transactions")
}

// ─── Achievements (learning engine — schema only in UI) ─────────────────────

enum AchievementCriteriaType {
  first_lesson_completed
  points_threshold
  first_module_completed
  lessons_completed_count
}

model Achievement {
  id           String                  @id @default(uuid()) @db.Uuid
  code         String                  @unique @db.VarChar(64)
  title        String                  @db.VarChar(255)
  description  String?                 @db.Text
  criteriaType AchievementCriteriaType @map("criteria_type")
  threshold    Int                     @default(0)
  isActive     Boolean                 @default(true) @map("is_active")
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  studentAchievements StudentAchievement[]

  @@index([code])
  @@index([criteriaType])
  @@map("achievements")
}

model StudentAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  earnedAt      DateTime @default(now()) @map("earned_at") @db.Timestamptz(6)

  student     User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementId])
  @@index([studentId])
  @@index([achievementId])
  @@map("student_achievements")
}

// ─── Maestro Board ───────────────────────────────────────────────────────────

model NewsPost {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  content     String    @db.Text
  authorId    String    @map("author_id") @db.Uuid
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([isPublished, publishedAt])
  @@index([authorId])
  @@index([deletedAt])
  @@map("news_posts")
}

// ─── Push notifications ──────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.VarChar(2048)
  p256dh    String   @db.VarChar(255)
  auth      String   @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  entityType String      @map("entity_type") @db.VarChar(64)
  entityId   String      @map("entity_id") @db.Uuid
  action     AuditAction
  actorId    String?     @map("actor_id") @db.Uuid
  payload    Json?       @db.JsonB
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
